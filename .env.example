CHROMA_PLACES_COLLECTION=places_collection
CHROMA_POSTS_COLLECTION=posts_collection
VECTOR_STORE_MODE=mock
VECTOR_STORE_PROVIDER=mock

PGVECTOR_DSN=
PGVECTOR_SSL=require
PGVECTOR_HOST=
PGVECTOR_PORT=5432
PGVECTOR_DATABASE=
PGVECTOR_USER=
PGVECTOR_PASSWORD=
